# Copy this file to .env and fill in real values. Never commit .env.
SERPAPI_KEY=your_serpapi_key_here
ANTHROPIC_API_KEY=your_anthropic_key_here

# Amazon domain to query via SerpAPI (India = amazon.in)
AMAZON_DOMAIN=amazon.in

# Default category this system is tuned for (Phase 1 scope)
DEFAULT_CATEGORY=wireless earphones

# Cache TTL (seconds) for live SerpAPI results, to avoid re-hitting the API
# on every request within a session
SERPAPI_CACHE_TTL=900

# Max SERP pages to pull per query
SERPAPI_MAX_PAGES=3

# CORS origin for the frontend dev server
FRONTEND_ORIGIN=http://localhost:5173
